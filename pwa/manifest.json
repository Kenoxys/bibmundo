{
  "name": "Biblioteca Mundo Hispano",
  "short_name": "BibMundo",
  "description": "Catálogo de recursos bíblicos en español. Funciona offline como PWA.",
  "start_url": "/pwa/index.html",
  "scope": "/",
  "lang": "es",
  "dir": "ltr",
  "orientation": "portrait",
  "categories": ["books", "education"],
  "display": "standalone",
